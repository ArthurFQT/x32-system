{
  "name": "x32-server",
  "version": "1.0.0",
  "description": "Backend do sistema de controle de retorno da X32",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node ../scripts/run-env.cjs dev ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:prod": "node ../scripts/run-env.cjs prod ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "yarn run start:prod",
    "start:dev": "node ../scripts/run-env.cjs dev node dist/server.js",
    "start:prod": "node ../scripts/run-env.cjs prod node dist/server.js"
  },
  "keywords": [
    "x32",
    "socket.io",
    "express",
    "osc"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.8",
    "@types/qrcode": "^1.5.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
